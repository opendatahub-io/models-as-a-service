        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "editorMode": "code",
          "expr": "sum by (subscription) (sum_over_time({service_name=\"maas-gateway\", response_code=~\"2..\", subscription=~\"$maas_subscription\", model=~\"$maas_model\"} | user_id=~\"$maas_user\" | user_id!=\"-\" | unwrap tokens_total [30m]))",
          "queryType": "range",
