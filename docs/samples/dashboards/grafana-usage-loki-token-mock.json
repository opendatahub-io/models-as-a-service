      "pluginName": "Loki"
    }
  ],
  "annotations": { "list": [] },
  "description": "Reference charts for filled token time series (Grafana). OpenShift Console Perses often omits area fill for Loki-backed TimeSeriesChart; import this into Grafana for mock/target UX.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 45,
            "gradientMode": "opacity",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "smooth",
            "lineWidth": 3,
            "pointSize": 8,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": [], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "editorMode": "code",
          "expr": "sum by (model) (sum_over_time({service_name=\"maas-gateway\", response_code=~\"2..\", subscription=~\"$maas_subscription\", model=~\"$maas_model\"} | user_id=~\"$maas_user\" | user_id!=\"-\" | unwrap tokens_total [30m]))",
          "queryType": "range",
          "refId": "A",
          "resolution": 1
        }
      ],
      "title": "Token consumption — by model (mock: filled / stacked)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 45,
