maas-api-image=quay.io/opendatahub/maas-api:latest
maas-controller-image=quay.io/opendatahub/maas-controller:latest
payload-processing-image=quay.io/opendatahub/odh-ai-gateway-payload-processing@sha256:203f2a056e265220bbb386e88caa5fe08063950ffc7e752120e5449ad8ef6013
gateway-namespace=openshift-ingress
gateway-name=maas-default-gateway
# IMPORTANT: app-namespace must match 'namespace:' in overlay kustomization.yaml
# Used for AuthPolicy URL (maas-api.<app-namespace>.svc) and DestinationRule host
app-namespace=opendatahub
api-key-max-expiration-days=90
metadata-cache-ttl=60
authz-cache-ttl=60
