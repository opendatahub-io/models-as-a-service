maas-api-image=quay.io/opendatahub/maas-api:odh-stable
maas-controller-image=quay.io/opendatahub/maas-controller:odh-stable
payload-processing-image=quay.io/opendatahub/odh-ai-gateway-payload-processing:odh-stable
maas-api-key-cleanup-image=registry.redhat.io/ubi9/ubi-minimal:9.7
payload-processing-replicas=1
gateway-namespace=openshift-ingress
gateway-name=maas-default-gateway
# payload-processing runs in the gateway namespace for kustomize deployments.
# The RHOAI operator overrides this to the app namespace (NamespaceApplierPlugin
# moves all resources to the app namespace).
payload-processing-namespace=openshift-ingress
# Infrastructure namespace for maas-api deployment and maas-db-config secret.
# Note: PostgreSQL can be external (e.g., AWS RDS) - only maas-api and the connection secret deploy here.
# Currently set to controller namespace (opendatahub) for backward compatibility.
# Used for AuthPolicy URL (maas-api.<infra-namespace>.svc) and DestinationRule host.
# Note: The operator may override this value in the maas-parameters ConfigMap.
# TODO: When namespace separation becomes the default, change to: infra-namespace=AUTO
infra-namespace=opendatahub
api-key-max-expiration-days=90
metadata-cache-ttl=60
authz-cache-ttl=60
# Cluster audience for kubernetesTokenReview (clusters with custom OIDC issuers override this)
cluster-audience=https://kubernetes.default.svc
