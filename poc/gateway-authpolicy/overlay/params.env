# PoC parameters — fill in before running kustomize build
#
# maas-api namespace (where maas-api service is deployed)
app-namespace=maas-api

# Gateway namespace and name (where the AuthPolicy will be created)
gateway-namespace=openshift-ingress
gateway-name=maas-default-gateway

# OIDC audience for kubernetesTokenReview
# Standard: https://kubernetes.default.svc
# HyperShift/ROSA: use your custom OIDC provider URL
cluster-audience=https://kubernetes.default.svc

# Cache TTLs (seconds)
# metadata-cache-ttl: how long API key and subscription lookups are cached
# authz-cache-ttl:    how long OPA authorization results are cached
#                     must not exceed metadata-cache-ttl (or it is clamped)
metadata-cache-ttl=300
authz-cache-ttl=300
